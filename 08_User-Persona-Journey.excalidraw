      "roundness": null,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "ส่งไวมาก ทันวันเกิดพอดี\nห่อหนาแน่นดี\nลูกชายบอกเสียงดีและใส่สบายมาก\nโล่งอกไปที!",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
