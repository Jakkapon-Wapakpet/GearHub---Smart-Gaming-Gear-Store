      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "จะต้องไปซื้อหูฟังแบบไหนนะ\nไม่มีความรู้เลย\nกลัวเดินเข้าร้านแล้วพนักงานขายจะแนะนำแพงๆ\nให้",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
