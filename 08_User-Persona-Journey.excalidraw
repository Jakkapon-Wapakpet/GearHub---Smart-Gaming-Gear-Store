        "group_persona_1"
      ],
      "frameId": null,
      "roundness": null,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "• อายุ: 19 ปี (นักศึกษาคณะมนุษยศาสตร์)\n• พฤติกรรม: เล่นเกมแนว Cozy เช่น Genshin, Stardew, Sims\n• การใช้งาน: เล่นเกมผ่อนคลายและใช้พิมพ์รายงานศึกษา",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• อายุ: 19 ปี (นักศึกษาคณะมนุษยศาสตร์)\n• พฤติกรรม: เล่นเกมแนว Cozy เช่น Genshin, Stardew, Sims\n• การใช้งาน: เล่นเกมผ่อนคลายและใช้พิมพ์รายงานศึกษา",
      "lineHeight": 1.2
    },
    {
