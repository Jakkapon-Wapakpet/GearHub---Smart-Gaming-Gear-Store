      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "\nลูกชายบ่นว่าหูฟังเกมมิ่งอันเดิมเสียงไม่ดัง\nหักชำรุด\nเลยอยากซื้อหูฟังอันใหม่ให้เป็นของขวัญวันเกิดสัปดาห์หน้า",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nลูกชายบ่นว่าหูฟังเกมมิ่งอันเดิมเสียงไม่ดัง\nหักชำรุด\nเลยอยากซื้อหูฟังอันใหม่ให้เป็นของขวัญวันเกิดสัปดาห์หน้า",
      "lineHeight": 1.2
    },
