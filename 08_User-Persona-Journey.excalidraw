    {
      "id": "c61f3a16",
      "type": "text",
      "x": 120,
      "y": 1005,
      "width": 357.5,
      "height": 48,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
