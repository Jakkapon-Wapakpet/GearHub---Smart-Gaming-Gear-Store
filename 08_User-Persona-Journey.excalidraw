        "group_persona_3"
      ],
      "frameId": null,
      "roundness": null,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "\nตัดสินใจเลือกสั่งรุ่นยอดนิยมที่รีวิวดีที่สุด\nราคา 2,400 บาท\nซื้อโดยไม่ต้องสมัครสมาชิกและกดจ่ายผ่านแอปธนาคารบนมือถือ",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nตัดสินใจเลือกสั่งรุ่นยอดนิยมที่รีวิวดีที่สุด\nราคา 2,400 บาท\nซื้อโดยไม่ต้องสมัครสมาชิกและกดจ่ายผ่านแอปธนาคารบนมือถือ",
      "lineHeight": 1.2
    },
