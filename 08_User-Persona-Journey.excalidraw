      "type": "text",
      "x": 120,
      "y": 1935,
      "width": 357.5,
      "height": 80,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
