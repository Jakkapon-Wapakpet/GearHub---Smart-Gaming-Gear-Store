      "type": "text",
      "x": 1110,
      "y": 2275,
      "width": 605,
      "height": 104,
      "strokeColor": "#1e293b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
